{
  "_readme": [
    "VALARX theme — single source of truth for branding and design tokens.",
    "Edit values here, then run `node scripts/generate-theme.mjs` from the frontend folder.",
    "(It also runs automatically before `npm run dev` and `npm run build`.)",
    "Any value may reference a color token with {token-name}, e.g. \"background\": \"{primary}\".",
    "Output: app/theme.css — generated, never edit that file by hand.",
    "Direction (FRONTEND_REMODEL_BLUEPRINT.md): neutral dark base; lime is the primary",
    "accent, purple ('brand') is a secondary accent for tints/gradients — never a surface."
  ],
  "colors": {
    "primary": "#111114",
    "secondary": "#1a1a1f",
    "accent": "#a7ff04",
    "accent-hover": "#91db03",
    "accent-dim": "#6b9e02",
    "brand": "#42169b",
    "brand-deep": "#300a86",
    "background": "{primary}",
    "background-dark": "#0c0c0e",
    "background-deepest": "#242429",
    "text": "#f5f5f7",
    "text-on-accent": "{background-dark}",
    "error": "#ff6b6b"
  },
  "typography": {
    "fonts": {
      "sans": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif",
      "mono": "var(--font-geist-mono), ui-monospace, monospace"
    },
    "scale": {
      "display": "3.75rem/1.05",
      "h1": "2.25rem/1.15",
      "h2": "1.5rem/1.3",
      "body": "1rem/1.6",
      "small": "0.875rem/1.5",
      "label": "0.75rem/1.4"
    },
    "eyebrow": {
      "size": "0.75rem",
      "weight": "600",
      "tracking": "0.1em"
    }
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "slot": "0.25rem"
  },
  "shadows": {
    "panel": "0 1px 2px rgba(0, 0, 0, 0.4), 0 8px 24px rgba(0, 0, 0, 0.25)",
    "modal": "0 25px 50px -12px rgba(0, 0, 0, 0.65)",
    "glow": "0 4px 20px rgba(0, 0, 0, 0.4)",
    "glow-strong": "0 8px 28px rgba(0, 0, 0, 0.5)",
    "accent": "0 0 24px color-mix(in srgb, {accent} 18%, transparent)",
    "card-lift": "0 16px 40px -12px rgba(0, 0, 0, 0.55)",
    "hero-glow": "0 40px 60px -30px rgba(0, 0, 0, 0.5)"
  },
  "motion": {
    "durations": {
      "fast": "150ms",
      "base": "200ms",
      "slow": "400ms"
    },
    "easings": {
      "smooth": "cubic-bezier(0.16, 1, 0.3, 1)",
      "snap": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  }
}
