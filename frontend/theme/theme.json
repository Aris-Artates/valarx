{
  "_readme": [
    "VALARX theme — single source of truth for branding and design tokens.",
    "Edit values here, then run `node scripts/generate-theme.mjs` from the frontend folder.",
    "(It also runs automatically before `npm run dev` and `npm run build`.)",
    "Any value may reference a color token with {token-name}, e.g. \"background\": \"{primary}\".",
    "Output: app/theme.css — generated, never edit that file by hand."
  ],
  "colors": {
    "primary": "#300a86",
    "secondary": "#42169b",
    "accent": "#a7ff04",
    "accent-hover": "#91db03",
    "accent-dim": "#6b9e02",
    "background": "{primary}",
    "background-dark": "#230761",
    "background-deepest": "#0f005c",
    "text": "#ffffff",
    "text-on-accent": "{background-deepest}"
  },
  "typography": {
    "fonts": {
      "sans": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif",
      "mono": "var(--font-geist-mono), ui-monospace, monospace"
    },
    "scale": {
      "display": "3.75rem/1.05",
      "h1": "2.25rem/1.15",
      "h2": "1.5rem/1.3",
      "body": "1rem/1.6",
      "small": "0.875rem/1.5",
      "label": "0.75rem/1.4"
    },
    "eyebrow": {
      "size": "0.75rem",
      "weight": "600",
      "tracking": "0.1em"
    }
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "slot": "0.25rem"
  },
  "shadows": {
    "panel": "0 0 10px rgba(0, 0, 0, 0.25)",
    "modal": "0 25px 50px -12px {background-deepest}",
    "glow": "0 0 14px color-mix(in srgb, {accent} 20%, transparent)",
    "glow-strong": "0 0 24px color-mix(in srgb, {accent} 35%, transparent)",
    "card-lift": "0 3vh 6vh -1.5vh {background-deepest}",
    "hero-glow": "0 40px 60px 20px {primary}"
  },
  "motion": {
    "durations": {
      "fast": "150ms",
      "base": "200ms",
      "slow": "400ms"
    },
    "easings": {
      "smooth": "cubic-bezier(0.16, 1, 0.3, 1)",
      "snap": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  }
}
