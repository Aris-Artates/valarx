APP_ENV=development

# Meta app credentials — used by scripts/get_page_token.py to mint the page
# token below. From developers.facebook.com > your app > App settings > Basic.
FB_APP_ID=
FB_APP_SECRET=

# Facebook page stats (GET /facebook/stats). Leave unset until ready — the
# endpoint returns 503 and the frontend hides the stats strip.
# Fill both by running scripts/get_page_token.py (instructions in that file).
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
